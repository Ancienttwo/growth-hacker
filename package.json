{
  "name": "growth-hacker",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun scripts/dev-all.ts",
    "dev:server": "bun --filter @growth-hacker/server dev",
    "dev:web": "bun --filter @growth-hacker/web dev",
    "build": "bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test apps packages",
    "yt-cli": "bun --silent packages/youtube-cli/src/cli.ts",
    "yt-cli:live-smoke": "bun scripts/youtube-cli-live-smoke.ts",
    "lint": "bun run typecheck",
    "check:brain-manifest": "repo-harness run check-brain-manifest",
    "check:context-files": "repo-harness run check-context-files",
    "check:deploy-sql": "repo-harness run check-deploy-sql-order",
    "check:task-sync": "repo-harness run check-task-sync",
    "check:task-workflow": "repo-harness run check-task-workflow --strict",
    "sync:brain-docs": "repo-harness run sync-brain-docs --all",
    "check:architecture-sync": "repo-harness run check-architecture-sync",
    "growthctl": "bun --silent apps/growthctl/src/cli.ts",
    "test:video-agent": "bun test \"$PWD/packages/video-agent/test/video-agent.test.ts\" \"$PWD/apps/server/test/videoWorkflow.test.ts\"",
    "verify:video-agent": "bash scripts/verify-video-agent.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@vitejs/plugin-react": "^5.1.1",
    "hono": "^4.10.8",
    "lucide-react": "^0.562.0",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  }
}
