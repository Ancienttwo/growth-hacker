{
  "name": "growth-hacker",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun scripts/dev-all.ts",
    "dev:server": "bun --filter @growth-hacker/server dev",
    "dev:web": "bun --filter @growth-hacker/web dev",
    "build": "bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test apps packages",
    "yt-cli": "bun --silent packages/youtube-cli/src/cli.ts",
    "yt-cli:live-smoke": "bun scripts/youtube-cli-live-smoke.ts",
    "lint": "bun run typecheck",
    "check:brain-manifest": "bash .ai/harness/scripts/check-brain-manifest.sh",
    "check:context-files": "bash .ai/harness/scripts/check-context-files.sh",
    "check:deploy-sql": "bash .ai/harness/scripts/check-deploy-sql-order.sh",
    "check:task-sync": "bash .ai/harness/scripts/check-task-sync.sh",
    "check:task-workflow": "bash .ai/harness/scripts/check-task-workflow.sh --strict",
    "sync:brain-docs": "bash .ai/harness/scripts/sync-brain-docs.sh --all",
    "check:architecture-sync": "bash .ai/harness/scripts/check-architecture-sync.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@vitejs/plugin-react": "^5.1.1",
    "hono": "^4.10.8",
    "lucide-react": "^0.562.0",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  }
}
